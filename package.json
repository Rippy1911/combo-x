{
  "name": "combo-x",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "pnpm --filter @combo-x/extension build",
    "dev": "pnpm --filter @combo-x/extension dev",
    "typecheck": "tsc --build",
